#!/bin/bash

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

if ! command -v stow &> /dev/null
then
    echo "stow could not be found, please install"
    exit
fi

cd "${SCRIPT_DIR}/.."

for PACKAGE in bash atom docker git gnupg misc perl personal postgres ruby tmux vim vscode
do
  stow -v $PACKAGE
done

# decrypt and install
script/decrypt-and-bootstrap
